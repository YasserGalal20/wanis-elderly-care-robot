+    // Set IMU covariances once here — they persist for the lifetime of imu_msg_.
+    // Without these, all covariance arrays default to zero, which robot_localization
+    // treats as "perfect measurement" and the EKF snaps to every reading unfiltered.
+    //
+    // Values based on BNO085 datasheet:
+    //   orientation: ~1 deg RMS   → variance = (0.01745 rad)² ≈ 0.0003 rad²
+    //   gyroscope:   ~0.5 deg/s   → variance = (0.00873 rad/s)² ≈ 0.0001 (rad/s)²
+    //   accelerometer: ~0.08 m/s² → variance = (0.08)² ≈ 0.01 m²/s⁴
+    //
+    // Diagonal indices in the row-major 3×3: [0]=xx, [4]=yy, [8]=zz.
+    this->imu_msg_.orientation_covariance[0] = 0.0003;
+    this->imu_msg_.orientation_covariance[4] = 0.0003;
+    this->imu_msg_.orientation_covariance[8] = 0.0003;
+    this->imu_msg_.angular_velocity_covariance[0] = 0.0001;
+    this->imu_msg_.angular_velocity_covariance[4] = 0.0001;
+    this->imu_msg_.angular_velocity_covariance[8] = 0.0001;
+    this->imu_msg_.linear_acceleration_covariance[0] = 0.01;
+    this->imu_msg_.linear_acceleration_covariance[4] = 0.01;
+    this->imu_msg_.linear_acceleration_covariance[8] = 0.01;
+
     if (publish_imu_) {
